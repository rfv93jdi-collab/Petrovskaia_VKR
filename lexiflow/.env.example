# Ключ для API (Google AI Studio или прокси / LLM-хост).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Опционально: базовый URL Gemini-совместимого API, если не прямой Google.
# Примеры: https://generativelanguage.googleapis.com (по умолчанию в SDK) или URL вашего прокси.
# Дублирующий алиас: GEMINI_API_BASE_URL (если задан, используется, если нет GOOGLE_GEMINI_BASE_URL).
# GOOGLE_GEMINI_BASE_URL="https://your-llm-host.example"
# GEMINI_API_BASE_URL=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
